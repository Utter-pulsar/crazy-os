{
  "name": "crazy_os",
  "version": "0.0.2",
  "description": "An AI-rendered, hand-drawn imaginary operating system. The UI is a file the model writes; the app renders it live.",
  "desktopName": "Crazy OS",
  "main": "./out/main/index.js",
  "author": "Utter_pulsar",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --dir --publish never",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --x64 --publish never",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.9.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.8.5",
    "framer-motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "roughjs": "^4.6.6",
    "zustand": "^5.0.14"
  }
}
